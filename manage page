<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Fanatic Magazine Management</title>
     <nav>
        <a href="index.html">HomePage</a>
    </nav>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" 
          rel="stylesheet" 
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" 
          crossorigin="anonymous"><!-- [web:13][web:19] -->
</head>
<body>
    <hr>

    <h2> Add / Update Clothing Item</h2>

    <form id="productForm">

<label for="imageURL">Product Image URL (optional)</label><br>
<input type="text" id="imageURL" placeholder="Enter image URL"><br><br>

<label for="productID">Product ID (required)</label><br>
<input type="number" id="productID" required><br><br>
<label for="title">Product Title (required)</label><br>
<input type="text" id="title" required><br><br>

<label for="type">Type of Clothing (required)</label><br>
<input type="text" id="type" required><br><br>

<label for="category">Category (required)</label><br>
<input type="text" id="category" required><br><br>

<label for="price">Price (required)</label><br>
<input type="number" id="price" placeholder="Not sold on webpage" required><br><br>

<label for="extra">Additional Information (optional)</label><br>
<input type="text" id="extra"><br><br>
        <button type="submit">Save Product</button>

    </form>

    <hr>

    <h2>Search Product</h2>

    <label for="searchInput">Search by Product ID:</label><br>
    <input type="number" id="searchInput">
    <button type="button" id="searchButton">Search</button>

    <hr>

    <h2>Product List</h2>

    <table border="1">
        <thead>
    <tr>
        <th>Image</th>
        <th>Product ID</th>
        <th>Title</th>
        <th>Type</th>
        <th>Category</th>
        <th>Price</th>
        <th>Additional Info</th>
        <th>Actions</th>
    </tr>
</thead>
        <tbody id="productTableBody">
            
        </tbody>
    </table>

</body>
</html>
